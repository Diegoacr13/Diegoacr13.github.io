---
import { marked } from 'marked';
import type { Hero as HeroProps } from '../types';
import Button from './Button.astro';
import CustomImage from './CustomImage.astro';

type Props = HeroProps;

const { title, image, text, actions, skills } = Astro.props;
---

{
  (title || image?.src || text || (actions && actions.length > 0)) && (
    <section class="mb-16 flex w-full flex-col gap-8 sm:mb-24 lg:flex-row lg:items-center lg:gap-12">
      
      <!-- Bloque de texto -->
      <div class="flex-1 min-w-0">
        
        {title && (
          <h1 class="font-serif text-3xl leading-tight font-medium sm:text-5xl sm:leading-tight whitespace-nowrap">
            {title}
          </h1>
        )}

        {text && (
          <div
            class="prose sm:prose-lg max-w-none mt-4"
            set:html={marked.parse(text)}
          />
        )}

        {/* 🔥 SKILLS CON ICONOS */}
        {skills && (
          <div class="mt-8">
            <h3 class="text-lg font-semibold mb-4">
              Skills
            </h3>

            <ul class="space-y-4">
              {skills.map((skill) => (
                <li class="flex items-start gap-3">
                  
                  {/* Icono */}
                  <span class="text-xl">
                    {skill.icon}
                  </span>

                  {/* Texto */}
                  <div>
                    <p class="font-medium">
                      {skill.name}
                    </p>
                    <p class="text-sm text-gray-600">
                      {skill.desc}
                    </p>
                  </div>

                </li>
              ))}
            </ul>
          </div>
        )}

        {actions && actions.length > 0 && (
          <div class="flex flex-wrap gap-4 mt-6">
            {actions.map((action) => (
              <Button href={action.href}>{action.text}</Button>
            ))}
          </div>
        )}

      </div>

      <!-- Bloque de imagen -->
      {image?.src && (
        <div class="flex-1 flex justify-center">
          <CustomImage
            class="w-64 h-auto rounded-full shadow-lg"
            {...image}
            widths={[200, 400, 600]}
            sizes="300px"
            fetchpriority="high"
            loading="eager"
          />
          {image.caption && (
            <figcaption class="mt-1.5 text-xs sm:text-sm text-center">
              {image.caption}
            </figcaption>
          )}
        </div>
      )}

    </section>
  )
}